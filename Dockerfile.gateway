FROM nousresearch/hermes-agent:latest
RUN . /opt/hermes/.venv/bin/activate && uv pip install "hindsight-client>=0.4.22"

# Auto-fix volume permissions for webui container access.
# Runs as root before the entrypoint drops privileges.
COPY docker-entrypoint-wrapper.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint-wrapper.sh
ENTRYPOINT ["/usr/local/bin/docker-entrypoint-wrapper.sh"]
