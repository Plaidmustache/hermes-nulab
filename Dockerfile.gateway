FROM nousresearch/hermes-agent:latest
RUN . /opt/hermes/.venv/bin/activate && uv pip install "hindsight-client>=0.4.22"

# No ENTRYPOINT override — let /init (s6-overlay) handle UID/GID remap,
# volume chown, config seeding, and skills sync via cont-init scripts.
# The compose CMD (config set + gateway run) is executed by
# main-wrapper.sh as the hermes user via s6-setuidgid.
#
# See: https://hermes-agent.nousresearch.com/docs/user-guide/docker
